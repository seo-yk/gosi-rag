# Choose which env file to load from shell before running, e.g.
# export FAQ_ENV_FILE=.env.local
# export FAQ_ENV_FILE=.env.openai
FAQ_ENV_FILE=.env.local

# Shared settings
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.5-flash
FAQ_CHUNKING_MODE=row
FAQ_EMBEDDING_MODE=title_body
FAQ_TOP_K=3
FAQ_INDEX_DIR=index

# Local embedding mode
FAQ_EMBEDDING_PROVIDER=local
LOCAL_EMBEDDING_MODEL=intfloat/multilingual-e5-small

# OpenAI embedding mode
# FAQ_EMBEDDING_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
